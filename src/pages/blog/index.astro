---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const allBlogPosts = await getCollection('blog');

const sortedPosts = allBlogPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = 'Blog | GemVoyage';
const description = 'Travel guides, tips, and stories from around the world.';
---

<Layout title={title}>
  <Navbar />
  <section>
    <div class="py-8">
      <div class="container mx-auto px-4">
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-2">GemVoyage Blog</h1>
          <p class="text-gray-600">
            {description}
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedPosts.map((post) => (
            <article class="border border-gray-200 rounded-lg overflow-hidden transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
              <a href={`/blog/${post.slug}/`} class="block">
                {post.data.image && (
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    loading="lazy"
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-4">
                  <h2 class="text-xl font-semibold mb-2 hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-600 mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                  <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500 block mb-3">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="flex gap-2 flex-wrap">
                      {post.data.tags.map((tag) => (
                        <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
        
        {sortedPosts.length === 0 && (
          <div class="text-center py-16">
            <h3 class="text-xl font-semibold mb-2">No blog posts yet</h3>
            <p class="text-gray-600">Check back soon for exciting travel stories and guides!</p>
          </div>
        )}
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>