---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const allBlogPosts = await getCollection('blog');

// Get URL parameters
const url = Astro.url;
const searchQuery = url.searchParams.get('search') || '';
const selectedTag = url.searchParams.get('tag') || 'All';

// Get all unique tags from posts
const allTags = ['All', ...new Set(allBlogPosts.flatMap(post => post.data.tags))].sort();

// Filter posts based on search and tag
let filteredPosts = allBlogPosts.filter(post => {
  const matchesTag = selectedTag === 'All' || post.data.tags.includes(selectedTag);
  const matchesSearch = !searchQuery.trim() || 
    post.data.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
    post.data.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
    post.data.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));
  
  return matchesTag && matchesSearch;
});

// Sort filtered posts by date
const sortedPosts = filteredPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = 'Blog | GemVoyage';
const description = 'Travel guides, itinieraries, rank lists, and more to help you make the best out of your travels.';

// Helper function for building URLs
function buildURL(params: Record<string, string | null>) {
  const newURL = new URL(url);
  newURL.search = '';
  
  Object.entries(params).forEach(([key, value]) => {
    if (value !== null && value !== '' && !(key === 'tag' && value === 'All')) {
      newURL.searchParams.set(key, value);
    }
  });
  
  return newURL.pathname + newURL.search;
}
---

<Layout title={title}>
  <Navbar />
  <section>
    <div class="py-8">
      <div class="container mx-auto px-4">
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-2">GemVoyage Blog</h1>
          <p class="text-gray-600">
            {description}
          </p>
        </div>
        
        <!-- Search and Filter Section -->
        <div class="flex flex-col md:flex-row gap-6 mb-8">
          <div class="md:w-2/3">
            <form id="search-form" class="relative" method="GET">
              <input 
                id="search-input"
                name="search"
                type="text"
                value={searchQuery}
                placeholder="Search by title, description, or tags" 
                class="pl-5 w-full text-lg border-2 rounded-xl p-3 shadow focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
              />
              <input type="hidden" name="tag" value={selectedTag} />
            </form>
          </div>
          
          <div class="flex flex-col sm:flex-row gap-4 md:w-1/3">
            <select 
              id="tag-select"
              name="tag"
              class="w-full text-lg border-2 rounded-xl p-3 shadow focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
            >
              {allTags.map(tag => (
                <option value={tag} selected={tag === selectedTag}>
                  {tag}
                </option>
              ))}
            </select>
          </div>
        </div>
        
        <!-- Results Info -->
        {sortedPosts.length > 0 && (
          <div class="mb-6 text-gray-600">
            {(() => {
              const hasFilters = searchQuery.trim() || selectedTag !== 'All';
              return hasFilters 
                ? `Found ${sortedPosts.length} ${sortedPosts.length === 1 ? 'post' : 'posts'}`
                : `Showing ${sortedPosts.length} ${sortedPosts.length === 1 ? 'post' : 'posts'}`;
            })()}
          </div>
        )}
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedPosts.map((post) => (
            <article class="border border-gray-200 rounded-lg overflow-hidden transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
              <a href={`/blog/${post.id}/`} class="block">
                {post.data.image && (
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    loading="lazy"
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-4">
                  <h2 class="text-xl font-semibold mb-2 hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-600 mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                  <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500 block mb-3">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="flex gap-2 flex-wrap">
                      {post.data.tags.map((tag) => (
                        <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
        
        {sortedPosts.length === 0 && (
          <div class="text-center py-16">
            <h3 class="text-xl font-semibold mb-2">No blog posts found</h3>
            <p class="text-gray-600 mb-6">
              {searchQuery || selectedTag !== 'All' 
                ? 'Try adjusting your filters or search query'
                : 'Check back soon for exciting travel stories and guides!'}
            </p>
            {(searchQuery || selectedTag !== 'All') && (
              <a 
                href="/blog"
                class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors inline-block"
              >
                Clear Filters
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Handle search form submission
    const searchForm = document.getElementById('search-form');
    if (searchForm) {
      searchForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const searchInput = document.getElementById('search-input');
        const tagSelect = document.getElementById('tag-select');
        
        const params = new URLSearchParams();
        
        if (searchInput.value.trim()) {
          params.set('search', searchInput.value.trim());
        }
        
        if (tagSelect.value !== 'All') {
          params.set('tag', tagSelect.value);
        }
        
        const newURL = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
        window.location.href = newURL;
      });
    }

    // Handle tag change
    const tagSelect = document.getElementById('tag-select');
    if (tagSelect) {
      tagSelect.addEventListener('change', function() {
        const searchInput = document.getElementById('search-input');
        
        const params = new URLSearchParams();
        
        if (searchInput.value.trim()) {
          params.set('search', searchInput.value.trim());
        }
        
        if (tagSelect.value !== 'All') {
          params.set('tag', tagSelect.value);
        }
        
        const newURL = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
        window.location.href = newURL;
      });
    }
  });
</script>