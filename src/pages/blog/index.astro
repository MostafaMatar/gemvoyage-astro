---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const allBlogPosts = await getCollection('blog');

// Get URL parameters
const url = Astro.url;
const searchQuery = url.searchParams.get('search') || '';
const currentPage = parseInt(url.searchParams.get('page') || '1');
const postsPerPage = 9;

// Filter posts based on search only (tags filter removed)
let filteredPosts = allBlogPosts.filter(post => {
  const matchesSearch = !searchQuery.trim() || 
    post.data.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
    post.data.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
    post.data.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));
  
  return matchesSearch;
});

// Sort filtered posts by date
const sortedPosts = filteredPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Pagination calculations
const totalPosts = sortedPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const displayPosts = sortedPosts.slice(startIndex, endIndex);

const title = 'Blog | GemVoyage';
const description = 'Travel guides, itinieraries, rank lists, and more to help you make the best out of your travels.';

// Helper function for building URLs (no tag handling)
function buildURL(params: Record<string, string | number | null>) {
  const newURL = new URL(url);
  newURL.search = '';
  
  Object.entries(params).forEach(([key, value]) => {
    if (value !== null && value !== '') {
      if (!(key === 'page' && value === 1)) {
        newURL.searchParams.set(key, value.toString());
      }
    }
  });
  
  return newURL.pathname + newURL.search;
}

// Pre-compute pagination data
const pageNumbers = totalPages <= 10 ? Array.from({ length: totalPages }, (_, i) => {
  const pageNum = i + 1;
  return {
    pageNum,
    isActive: pageNum === currentPage,
    href: buildURL({ search: searchQuery, page: pageNum })
  };
}) : [];
---
<Layout title={title} description={description}>
  <Navbar />
  <section>
    <div class="py-8">
      <div class="container mx-auto px-4">
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-2">GemVoyage Blog</h1>
          <p class="text-gray-600">
            {description}
          </p>
        </div>
        
        <!-- Search Section (tag filter removed) -->
        <div class="flex flex-col md:flex-row gap-6 mb-8">
          <div class="md:w-full">
            <form id="search-form" class="relative" method="GET">
              <input 
                id="search-input"
                name="search"
                type="text"
                value={searchQuery}
                placeholder="Search by title, description, or tags" 
                class="pl-5 w-full text-lg border-2 rounded-xl p-3 shadow focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
              />
              <!-- removed hidden tag input -->
            </form>
          </div>
        </div>
        
        <!-- Results Info -->
        {totalPosts > 0 && (
          <div class="mb-6 text-gray-600">
            {(() => {
              const hasFilters = searchQuery.trim();
              const startPostIndex = startIndex + 1;
              const endPostIndex = Math.min(endIndex, totalPosts);
              
              return hasFilters 
                ? `Found ${totalPosts} ${totalPosts === 1 ? 'post' : 'posts'} • Page ${currentPage} of ${totalPages}`
                : `Showing ${endPostIndex - startPostIndex + 1} posts • Page ${currentPage} of ${totalPages}`;
            })()}
          </div>
        )}
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {displayPosts.map((post) => (
            <article class="border border-gray-200 rounded-lg overflow-hidden transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
              <a href={`/blog/${post.slug}/`} class="block">
                {post.data.image && (
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    loading="lazy"
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-4">
                  <h2 class="text-xl font-semibold mb-2 hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-600 mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                  <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500 block mb-3">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="flex gap-2 flex-wrap">
                      {post.data.tags.map((tag) => (
                        <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
        
        {sortedPosts.length === 0 && (
          <div class="text-center py-16">
            <h3 class="text-xl font-semibold mb-2">No blog posts found</h3>
            <p class="text-gray-600 mb-6">
              {searchQuery 
                ? 'Try adjusting your search query'
                : 'Check back soon for exciting travel stories and guides!'}
            </p>
            {searchQuery && (
              <a 
                href="/blog"
                class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors inline-block"
              >
                Clear Filters
              </a>
            )}
          </div>
        )}

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="flex justify-center items-center gap-2 mt-8">
            {currentPage > 1 && (
              <a 
                href={buildURL({ search: searchQuery, page: currentPage - 1 })}
                class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
              >
                Prev
              </a>
            )}
            
            <div class="flex gap-1">
              {totalPages <= 10 ? (
                pageNumbers.map((page) => (
                  <a 
                    href={page.href}
                    class={`px-3 py-1 text-sm rounded transition-colors ${page.isActive 
                      ? 'bg-blue-600 text-white' 
                      : 'border border-gray-300 hover:bg-gray-50'}`}
                  >
                    {page.pageNum}
                  </a>
                ))
              ) : (
                <span class="px-4 py-2 text-sm text-gray-600">
                  Page {currentPage} of {totalPages}
                </span>
              )}
            </div>
            
            {currentPage < totalPages && (
              <a 
                href={buildURL({ search: searchQuery, page: currentPage + 1 })}
                class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
              >
                Next
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Handle search form submission
    const searchForm = document.getElementById('search-form');
    if (searchForm) {
      searchForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const searchInput = document.getElementById('search-input');
        
        const params = new URLSearchParams();
        
        if (searchInput.value.trim()) {
          params.set('search', searchInput.value.trim());
        }
        
        // Reset to page 1 when searching
        const newURL = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
        window.location.href = newURL;
      });
    }

    // Tag select and its change handler removed (filtering by tag disabled)
  });
</script>