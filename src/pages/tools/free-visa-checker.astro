<script is:inline>
  // ─── CSV state ─────────────────────────────────────────────────────────────
  /** @type {string[] | null} destination country codes (column headers, index 0 = first dest) */
  let csvHeaders = null;
  /** @type {Map<string, string[]> | null} passportCode → array of visa values */
  let csvRows = null;

  async function loadCSV() {
    if (csvRows) return; // already loaded
    const res = await fetch('/visa-check.csv');
    if (!res.ok) throw new Error('Failed to load visa data');
    const text = await res.text();
    const lines = text.split(/\r?\n/).filter((l) => l.trim());

    // Header row: Passport,AL,DZ,AD,...
    const headerParts = lines[0].split(',');
    csvHeaders = headerParts.slice(1).map((c) => c.trim()); // skip "Passport"

    csvRows = new Map();
    for (let i = 1; i < lines.length; i++) {
      const parts = lines[i].split(',');
      const passport = parts[0].trim();
      if (passport) csvRows.set(passport, parts.slice(1));
    }
  }

  function lookupVisa(fromCode, toCode) {
    const row = csvRows.get(fromCode);
    if (!row) return null;
    const colIdx = csvHeaders.indexOf(toCode);
    if (colIdx === -1) return null;
    const val = row[colIdx];
    return val ? val.trim() : null;
  }

  function interpretRequirement(req) {
    const r = req.toLowerCase().trim().replace(/[\r\n]/g, '');

    if (r === '-1' || r === 'admission refused' || r === 'no admission') {
      return {
        status: 'admission_refused',
        label: 'Admission Refused',
        daysAllowed: null,
        description: 'Entry to this destination is not permitted for holders of your passport.',
      };
    }

    if (r === 'cb') {
      return {
        status: 'visa_free',
        label: 'Visa Free (CARICOM)',
        daysAllowed: null,
        description: 'As a CARICOM member state citizen, you can enter this destination visa-free.',
      };
    }

    if (r === 'voa' || r.startsWith('visa on arrival')) {
      const match = r.match(/(\d+)/);
      const days = match ? parseInt(match[1], 10) : null;
      return {
        status: 'visa_on_arrival',
        label: 'Visa on Arrival',
        daysAllowed: days,
        description: days
          ? `You can obtain a visa upon arrival at the airport or border crossing. Valid for up to ${days} days.`
          : 'You can obtain a visa upon arrival at the airport or border crossing.',
      };
    }

    if (r === 'eta' || r.includes('e-visa') || r.includes('evisa') || r.includes('electronic travel')) {
      return {
        status: 'e_visa',
        label: 'E-Visa / ETA Required',
        daysAllowed: null,
        description: 'You need an Electronic Travel Authorization (ETA) or e-visa, which you can apply for online before traveling. The process is typically fast and paperless.',
      };
    }

    if (r === 'vr' || r === 'visa required') {
      return {
        status: 'visa_required',
        label: 'Visa Required',
        daysAllowed: null,
        description: "You must apply for a visa from the destination country's embassy or consulate before traveling.",
      };
    }

    const numMatch = r.match(/^(\d+)$/);
    if (numMatch) {
      const days = parseInt(numMatch[1], 10);
      if (days > 0) {
        return {
          status: 'visa_free',
          label: 'Visa Free',
          daysAllowed: days,
          description: `Your passport allows visa-free entry for up to ${days} days. No visa application is required for tourism or short visits.`,
        };
      }
      return {
        status: 'visa_required',
        label: 'Visa Required',
        daysAllowed: null,
        description: 'You must apply for a visa before traveling to this destination.',
      };
    }

    if (r === 'vf' || r.startsWith('visa free') || r.startsWith('visa-free')) {
      const match = r.match(/(\d+)/);
      const days = match ? parseInt(match[1], 10) : null;
      return {
        status: 'visa_free',
        label: 'Visa Free',
        daysAllowed: days,
        description: days
          ? `Your passport allows visa-free entry for up to ${days} days. No visa application is required.`
          : 'Your passport allows visa-free entry. No visa application is required for tourism or short visits.',
      };
    }

    if (r.includes('passport not required') || r.includes('not required')) {
      return {
        status: 'visa_free',
        label: 'No Documents Required',
        daysAllowed: null,
        description: 'No visa or passport is required to enter this destination.',
      };
    }

    return {
      status: 'unknown',
      label: 'Data Unavailable',
      daysAllowed: null,
      description: 'Visa requirement information could not be determined for this combination. Please consult the official embassy or consulate of the destination country.',
    };
  }

