    { code: 'TH', name: 'Thailand' },
    { code: 'TJ', name: 'Tajikistan' },
    { code: 'TL', name: 'Timor-Leste' },
    { code: 'TM', name: 'Turkmenistan' },
    { code: 'TN', name: 'Tunisia' },
    { code: 'TO', name: 'Tonga' },
    { code: 'TR', name: 'Turkey' },
    { code: 'TT', name: 'Trinidad and Tobago' },
    { code: 'TV', name: 'Tuvalu' },
    { code: 'TZ', name: 'Tanzania' },
    { code: 'UA', name: 'Ukraine' },
    { code: 'UG', name: 'Uganda' },
    { code: 'US', name: 'United States' },
    { code: 'UY', name: 'Uruguay' },
    { code: 'UZ', name: 'Uzbekistan' },
    { code: 'VA', name: 'Vatican City' },
    { code: 'VC', name: 'Saint Vincent and the Grenadines' },
    { code: 'VE', name: 'Venezuela' },
    { code: 'VN', name: 'Vietnam' },
    { code: 'VU', name: 'Vanuatu' },
    { code: 'WS', name: 'Samoa' },
    { code: 'YE', name: 'Yemen' },
    { code: 'ZA', name: 'South Africa' },
    { code: 'ZM', name: 'Zambia' },
    { code: 'ZW', name: 'Zimbabwe' },
  ];

  // ─── DOM references ────────────────────────────────────────────────────────
  const fromFilter = document.getElementById('from-filter');
  const toFilter = document.getElementById('to-filter');
  const fromSelect = document.getElementById('from-select');
  const toSelect = document.getElementById('to-select');
  const fromError = document.getElementById('from-error');
  const toError = document.getElementById('to-error');
  const checkBtn = document.getElementById('check-btn');
  const loadingState = document.getElementById('loading-state');
  const resultSection = document.getElementById('result-section');
  const resultCard = document.getElementById('result-card');
  const errorBanner = document.getElementById('error-banner');
  const errorMessage = document.getElementById('error-message');
  const selectionSummary = document.getElementById('selection-summary');
  const fromSelectedLabel = document.getElementById('from-selected-label');
  const toSelectedLabel = document.getElementById('to-selected-label');

  // ─── Populate selects ──────────────────────────────────────────────────────
  function buildOptions(selectEl, countries) {
    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = '— Select a country —';
    placeholder.disabled = true;
    placeholder.selected = true;
    selectEl.appendChild(placeholder);

    countries.forEach(({ code, name }) => {
      const opt = document.createElement('option');
      opt.value = code;
      opt.textContent = name;
      selectEl.appendChild(opt);
    });
  }

  buildOptions(fromSelect, COUNTRIES);
  buildOptions(toSelect, COUNTRIES);

  // ─── Filter logic ──────────────────────────────────────────────────────────
  function filterSelect(filterInput, selectEl) {
    const query = filterInput.value.toLowerCase().trim();
    let firstVisible = null;
    Array.from(selectEl.options).forEach((opt) => {
      if (opt.disabled) return; // skip placeholder
      const visible = !query || opt.textContent.toLowerCase().includes(query);
      opt.hidden = !visible;
      if (visible && !firstVisible) firstVisible = opt;
    });
    // Auto-select if exactly one match
    if (firstVisible && query) {
      const visibleOpts = Array.from(selectEl.options).filter(
        (o) => !o.hidden && !o.disabled
      );
      if (visibleOpts.length === 1) {
        selectEl.value = visibleOpts[0].value;
        selectEl.dispatchEvent(new Event('change'));
      }
    }
  }

  fromFilter.addEventListener('input', () => filterSelect(fromFilter, fromSelect));
  toFilter.addEventListener('input', () => filterSelect(toFilter, toSelect));

  // ─── Selection summary update ──────────────────────────────────────────────
  function updateSummary() {
    const fromVal = fromSelect.value;
    const toVal = toSelect.value;
    if (fromVal && toVal) {
      const fromName = COUNTRIES.find((c) => c.code === fromVal)?.name ?? fromVal;
      const toName = COUNTRIES.find((c) => c.code === toVal)?.name ?? toVal;
      fromSelectedLabel.textContent = fromName;
      toSelectedLabel.textContent = toName;
      selectionSummary.classList.remove('hidden');
    } else {
      selectionSummary.classList.add('hidden');
    }
  }

  fromSelect.addEventListener('change', () => {
    fromError.classList.add('hidden');
    // Sync filter input text with selection
    const name = COUNTRIES.find((c) => c.code === fromSelect.value)?.name ?? '';
    fromFilter.value = name;
    updateSummary();
  });

  toSelect.addEventListener('change', () => {
    toError.classList.add('hidden');
    const name = COUNTRIES.find((c) => c.code === toSelect.value)?.name ?? '';
    toFilter.value = name;
    updateSummary();
  });

  // ─── Visa status config ────────────────────────────────────────────────────
  const STATUS_CONFIG = {
    visa_free: {
      containerCls: 'bg-green-50 border-green-300',
      iconCls: 'bg-green-600',
      textCls: 'text-green-800',
      badgeCls: 'bg-green-600 text-white',
      icon: '✓',
    },
    visa_on_arrival: {
      containerCls: 'bg-yellow-50 border-yellow-300',
      iconCls: 'bg-yellow-500',
      textCls: 'text-yellow-800',
      badgeCls: 'bg-yellow-500 text-white',
      icon: '⏱',
    },
    e_visa: {
      containerCls: 'bg-blue-50 border-blue-300',
      iconCls: 'bg-blue-600',
      textCls: 'text-blue-800',
      badgeCls: 'bg-blue-600 text-white',
      icon: '💻',
    },
    visa_required: {
      containerCls: 'bg-red-50 border-red-300',
      iconCls: 'bg-red-600',
      textCls: 'text-red-800',
      badgeCls: 'bg-red-600 text-white',
      icon: '✗',
    },
    admission_refused: {
      containerCls: 'bg-gray-100 border-gray-400',
      iconCls: 'bg-gray-700',
      textCls: 'text-gray-800',
      badgeCls: 'bg-gray-700 text-white',
      icon: '⛔',
    },
    unknown: {
      containerCls: 'bg-gray-50 border-gray-300',
      iconCls: 'bg-gray-500',
      textCls: 'text-gray-700',
      badgeCls: 'bg-gray-500 text-white',
      icon: '?',
    },
  };

  // ─── Tips per status ───────────────────────────────────────────────────────
  const STATUS_TIPS = {
    visa_required: [
      'Contact the destination country\'s embassy or consulate in your country',
      'Prepare required documents (passport, photos, financial proof, accommodation)',
      'Apply well in advance — processing times vary widely',
      'Check if travel insurance is required',
    ],
    visa_on_arrival: [
      'Bring a valid passport with at least 6 months of validity',
      'Carry a return or onward ticket as proof of departure',
      'Have sufficient funds in cash (fees often accepted in USD or EUR)',
      'Double-check the maximum stay allowed',
    ],
    e_visa: [
      'Apply only through the official government portal of the destination country',
      'Have a digital copy of your passport photo page ready',
      'Allow time for processing — usually 24–72 hours',
      'Print or save the approval email to present at the border',
    ],
    admission_refused: [
      'Check the official government sources for any exceptions or recent changes',
      'Third-country passports or dual-nationality holders may have different rules',
      'Consider contacting the destination country\'s embassy for official guidance',
    ],
  };

  // ─── Display result ────────────────────────────────────────────────────────
  function displayResult(data) {
    const cfg = STATUS_CONFIG[data.status] || STATUS_CONFIG.unknown;
    const tips = STATUS_TIPS[data.status];

    const fromName = COUNTRIES.find((c) => c.code === data.from)?.name ?? data.from;
    const toName = COUNTRIES.find((c) => c.code === data.to)?.name ?? data.to;

    const tipsHTML = tips
      ? `<div class="mt-4 p-4 bg-white/70 rounded-lg">
           <p class="text-sm font-semibold mb-2 ${cfg.textCls}">What to know:</p>
           <ul class="text-sm space-y-1 ${cfg.textCls} opacity-90">
             ${tips.map((t) => `<li class="flex gap-2"><span>•</span><span>${t}</span></li>`).join('')}
           </ul>
         </div>`
      : '';

    const daysHTML = data.daysAllowed
      ? `<span class="ml-2 text-sm font-medium px-2 py-0.5 rounded-full bg-white/60 ${cfg.textCls}">${data.daysAllowed} days</span>`
      : '';

    resultCard.className = `rounded-xl border p-5 sm:p-6 ${cfg.containerCls}`;
    resultCard.innerHTML = `
      <div class="flex items-start gap-4">
        <div class="${cfg.iconCls} text-white rounded-full w-12 h-12 flex items-center justify-center text-xl font-bold flex-shrink-0 select-none">
          ${cfg.icon}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="${cfg.badgeCls} text-sm font-semibold px-3 py-1 rounded-full">${data.label}</span>
            ${daysHTML}
          </div>
          <p class="text-sm text-muted-foreground mb-1">
            <span class="font-medium">${fromName}</span>
            <span> → </span>
            <span class="font-medium">${toName}</span>
          </p>
          <p class="${cfg.textCls} font-medium leading-relaxed">${data.description}</p>
          ${tipsHTML}
        </div>
      </div>
    `;

    hideError();
    resultSection.classList.remove('hidden');
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ─── UI helpers ────────────────────────────────────────────────────────────
  function setLoading(on) {
    checkBtn.disabled = on;
    loadingState.classList.toggle('hidden', !on);
  }

  function showError(msg) {
    errorMessage.textContent = msg;
    errorBanner.classList.remove('hidden');
    resultSection.classList.add('hidden');
  }

  function hideError() {
    errorBanner.classList.add('hidden');
  }

  // ─── Check handler ─────────────────────────────────────────────────────────
  async function handleCheck() {
    const fromCode = fromSelect.value;
    const toCode = toSelect.value;

    let valid = true;
    if (!fromCode) {
      fromError.classList.remove('hidden');
      valid = false;
    }
    if (!toCode) {
      toError.classList.remove('hidden');
      valid = false;
    }
    if (!valid) return;

    // Same-country shortcut
    if (fromCode === toCode) {
      displayResult({
        from: fromCode,
        to: toCode,
        status: 'visa_free',
        label: 'No Visa Required',
        daysAllowed: null,
        description: 'You are traveling to your home country. No visa is required.',
      });
      return;
    }

    setLoading(true);
    resultSection.classList.add('hidden');
    hideError();

    try {
      await loadCSV();
      const raw = lookupVisa(fromCode, toCode);
      if (!raw) {
        showError('Visa information not found for this combination. Please consult the official embassy or consulate.');
        return;
      }
      const interpreted = interpretRequirement(raw);
      displayResult({ from: fromCode, to: toCode, ...interpreted });
    } catch {
      showError('Unable to load visa data. Please check your connection and try again.');
    } finally {
      setLoading(false);
    }
  }

  checkBtn.addEventListener('click', handleCheck);

  // Allow pressing Enter in the filter inputs to trigger check
  [fromFilter, toFilter].forEach((input) => {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') handleCheck();
    });
  });
</script>

