---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Free Visa Checker - Check Visa Requirements Instantly | GemVoyage';
const pageDescription =
  'Check visa requirements for 190+ countries instantly with our free visa checker. Find out if you need a visa, can get one on arrival, or travel visa-free.';
const pageUrl = 'https://gemvoyage.net/tools/free-visa-checker';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="visa checker, visa requirements, free visa checker, do I need a visa, visa on arrival, visa free travel, travel requirements"
